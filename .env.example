# Bật đồng bộ giá cho mọi người (Supabase free + Vercel API)
# Copy sang .env.local khi dev; trên Vercel thêm trong Project Settings → Environment Variables

# Client (VITE_ — public)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server chỉ trên Vercel (không VITE_)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
ADMIN_SECRET=123456
